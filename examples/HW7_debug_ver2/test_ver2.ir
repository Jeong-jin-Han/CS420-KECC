fun i32 @add (i32, i32) {
init:
  bid: b0
  allocations:
    %l0:i32:p
    %l1:i32:q
    %l2:i32:ret
    %l3:i32:tmp

block b0:
  %b0:i0:i32 = load %l0:i32*
  %b0:i1:i32 = load %l1:i32*
  %b0:i2:i32 = add %b0:i0:i32 %b0:i1:i32
  %b0:i3:unit = store %b0:i2:i32 %l2:i32*
  ret %b0:i2:i32
}

fun i32 @main () {
init:
  bid: b0
  allocations:
    %l0:i32:arg0
    %l1:i32:arg1
    %l2:i32:ret

block b0:
  %b0:i0:unit = store 1:i32 %l0:i32*
  %b0:i1:unit = store 2:i32 %l1:i32*
  %b0:i2:i32 = call @add:[ret:i32 params:(i32, i32)]*(%l0:i32, %l1:i32)
  %b0:i3:unit = store %b0:i2:i32 %l2:i32*
  ret %b0:i2:i32
}
