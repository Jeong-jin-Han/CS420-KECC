fun i32 @main () {
init:
  bid: b0
  allocations: 
    %l0:[5 x i32]:a
    %l1:i32:len
    %l2:i32:sum
    %l3:i32:i
    %l4:i32:i

block b0:
  %b0:i0:unit = store 5:i32 %l1:i32*
  %b0:i1:unit = store 0:i32 %l2:i32*
  j b1()

block b1:
  %b1:i0:unit = store 0:i32 %l3:i32*
  j b2()

block b2:
  %b2:i0:i32 = load %l3:i32*
  %b2:i1:i32 = load %l1:i32*
  %b2:i2:u1 = cmp lt %b2:i0:i32 %b2:i1:i32
  br %b2:i2:u1, b3(), b5()

block b3:
  %b3:i0:i32* = getelementptr %l0:[5 x i32]* offset 0:i32
  %b3:i1:i32 = load %l3:i32*
  %b3:i2:i64 = typecast %b3:i1:i32 to i64
  %b3:i3:i64 = mul %b3:i2:i64 4:i64
  %b3:i4:i32* = getelementptr %b3:i0:i32* offset %b3:i3:i64
  %b3:i5:i32 = load %l3:i32*
  %b3:i6:unit = store %b3:i5:i32 %b3:i4:i32*
  j b4()

block b4:
  %b4:i0:i32 = load %l3:i32*
  %b4:i1:i32 = add %b4:i0:i32 1:i32
  %b4:i2:unit = store %b4:i1:i32 %l3:i32*
  j b2()

block b5:
  j b6()

block b6:
  %b6:i0:unit = store 0:i32 %l4:i32*
  j b7()

block b7:
  %b7:i0:i32 = load %l4:i32*
  %b7:i1:i32 = load %l1:i32*
  %b7:i2:u1 = cmp lt %b7:i0:i32 %b7:i1:i32
  br %b7:i2:u1, b8(), b10()

block b8:
  %b8:i0:i32 = load %l2:i32*
  %b8:i1:i32* = getelementptr %l0:[5 x i32]* offset 0:i32
  %b8:i2:i32 = load %l4:i32*
  %b8:i3:i64 = typecast %b8:i2:i32 to i64
  %b8:i4:i64 = mul %b8:i3:i64 4:i64
  %b8:i5:i32* = getelementptr %b8:i1:i32* offset %b8:i4:i64
  %b8:i6:i32 = load %b8:i5:i32*
  %b8:i7:i32 = add %b8:i0:i32 %b8:i6:i32
  %b8:i8:unit = store %b8:i7:i32 %l2:i32*
  j b9()

block b9:
  %b9:i0:i32 = load %l4:i32*
  %b9:i1:i32 = add %b9:i0:i32 1:i32
  %b9:i2:unit = store %b9:i1:i32 %l4:i32*
  j b7()

block b10:
  %b10:i0:i32 = load %l2:i32*
  %b10:i1:u1 = cmp eq %b10:i0:i32 10:i32
  %b10:i2:i32 = typecast %b10:i1:u1 to i32
  ret %b10:i2:i32

block b11:
  ret 0:i32
}