fun i32 @test () {
init:
  bid: b0
  allocations:

block b0:
  %b0:i0:i32 = 1:i32
  br %b0:i0:i32, b2(), b3()

block b2:
  j b6(1:i32)

block b3:
  j b6(1:i32)

block b4:
  ret 0:i32

block b5:
  j b6(0:i32)

block b6:
  %b6:p0:i32:t0
  %b6:i0:u1 = cmp ne %b6:p0:i32 0:i32
  br %b6:i0:u1, b4(), b5()
}
