fun i32 @single_location () {
init:
  bid: b666
  allocations:
    %l0:i32:x

block b666:
  j b0(undef:i32)

block b0:
  %b0:p0:i32:x

  %b0:i0:unit = nop
  %b0:i1:unit = call @sink:[ret:unit params:(i32)]*(%b0:p0:i32)
  %b0:i2:unit = nop
  switch undef:i32 default b1() [
    2:i32 b2(0:i32)
    3:i32 b3(0:i32)
  ]

block b1:
  %b1:i0:unit = nop
  %b1:i1:unit = call @sink:[ret:unit params:(i32)]*(0:i32)
  %b1:i2:unit = nop
  j b2(100:i32)

block b2:
  %b2:p0:i32:x
  %b2:i0:unit = nop
  %b2:i1:unit = call @sink:[ret:unit params:(i32)]*(%b2:p0:i32)
  %b2:i2:unit = nop
  j b3(200:i32)

block b3:
  %b3:p0:i32:x
  %b3:i0:unit = nop
  j b0(300:i32)
}